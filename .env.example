# 复制此文件为 .env，填入真实值后本地运行
# cp .env.example .env

# Alpha Vantage —— 全球宏观新闻情感
# 免费版限 25 次/天，申请地址：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# 雪球 JWT Token —— 港股实时行情
# 登录 xueqiu.com 后从 Cookie 中取 xq_a_token 字段
# 有效期约 30 天，过期需重新获取
XUEQIU_TOKEN=your_xueqiu_token_here

# 飞书 Bot Webhook —— Pipeline 完成后推送通知
# 在飞书群 → 群设置 → 机器人 → 添加自定义机器人 → 复制 Webhook URL
# 不填则跳过通知
LARK_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_token_here

# FastAPI 接口鉴权 Key —— 调用 /api/* 时放在 Header: X-API-Key
# 本地开发可留空（跳过鉴权），生产环境必须设置
API_KEY=your_api_key_here
